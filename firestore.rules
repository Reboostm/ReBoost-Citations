rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isClientOwner(clientId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == clientId;
    }

    function isAdminOrOwner(clientId) {
      return isAdmin() || isClientOwner(clientId);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    // Clients collection
    match /clients/{clientId} {
      allow read: if isAdminOrOwner(clientId);
      allow write: if isAdmin();
    }

    // Directories collection
    match /directories/{directoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Citations collection
    match /citations/{citationId} {
      allow read: if isAdmin() || isClientOwner(resource.data.clientId);
      allow write: if isAdmin();
    }

    // Jobs collection
    match /jobs/{jobId} {
      allow read: if isAdmin() || isClientOwner(resource.data.clientId);
      allow write: if isAdmin();
    }

    // Packages collection
    match /packages/{packageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reports collection
    match /reports/{reportId} {
      allow read: if isAdmin() || isClientOwner(resource.data.clientId);
      allow write: if isAdmin();
    }

    // Public share tokens for reports (no auth required)
    match /shareTokens/{token} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
